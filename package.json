{
  "name": "sentinel",
  "version": "0.5.0",
  "private": true,
  "description": "ARGUS — open-source 4D geospatial command center (satellites, aircraft, live maritime AIS, seismic, conflict, launches).",
  "type": "module",
  "workspaces": ["server", "web"],
  "scripts": {
    "dev": "concurrently -n server,web -c cyan,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "npm --prefix server run dev",
    "dev:web": "npm --prefix web run dev",
    "build": "npm --prefix web run build",
    "start": "npm --prefix server start",
    "test": "npm --prefix server test && npm --prefix web test",
    "verify-ais": "npm --prefix server run verify-ais"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "license": "MIT"
}
