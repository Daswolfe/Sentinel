{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ARGUS",
  "version": "0.5.0",
  "identifier": "io.github.daswolfe.argus",
  "build": {
    "frontendDist": "../web/dist",
    "beforeBuildCommand": "npm --prefix web run build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico", "icons/128x128.png", "icons/32x32.png"]
  }
}
