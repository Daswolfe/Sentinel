# ── ARGUS backend secrets ─────────────────────────────────────────
# Copy this file to `.env` IN THIS SAME FOLDER (the repo root — next to
# package.json). The backend reads it from here no matter where it's launched.
# `.env` is gitignored so your keys stay private.

# Port the backend listens on (REST + websocket relay).
BACKEND_PORT=8787

# Optional shared auth token. Leave blank on localhost. Set it before exposing
# the backend beyond your machine: REST then requires "Authorization: Bearer
# <token>" (or ?token=), the websocket requires /ws?token=<token>.
BACKEND_TOKEN=

# aisstream.io — free key from https://aisstream.io  (sign in with GitHub).
# Leave blank to run without live AIS; the frontend then uses its simulation.
AISSTREAM_KEY=

# OpenSky OAuth2 client credentials (optional — lifts aircraft rate limits).
# Create an API client at https://opensky-network.org  Account page.
OPENSKY_ID=
OPENSKY_SECRET=

# NASA FIRMS map key (thermal/fire layer). Free at firms.modaps.eosdis.nasa.gov.
# Leave blank to run without thermal data; the layer then reports OFF.
FIRMS_MAP_KEY=

# Phase B — public webcams + street-level imagery (both proxied server-side).
# Windy Webcams API key: https://api.windy.com/keys  (CCTV layer, default-off).
WINDY_WEBCAMS_KEY=
# Mapillary access token: https://www.mapillary.com/dashboard/developers
# (street-level image on surface-point click). Client-read token.
MAPILLARY_ACCESS_TOKEN=

# Cloudflare API token — future Net Outages layer (Cloudflare Radar). Optional,
# not yet wired. Create at dash.cloudflare.com → My Profile → API Tokens.
CLOUDFLARE_API_TOKEN=

# Google Maps Platform key — Photorealistic 3D Tiles at deep zoom (optional;
# without it the OSM Buildings extrusions are used instead). Delivered to the
# browser, so RESTRICT it in Google Cloud Console: HTTP referrers + Map Tiles
# API only. Google bills per ROOT tileset request (1,000 free per month, 2025
# pricing); the backend meters those and refuses new 3D sessions past the cap
# below, so a free-tier key never accrues charges. Belt-and-braces: also set a
# requests-per-day quota limit on the Map Tiles API in the Cloud Console.
GOOGLE_MAPS_KEY=
# Monthly root-request budget the backend will allow (default 900 of the 1,000
# free — keeps a safety margin).
GOOGLE_TILES_MONTHLY_CAP=

# Phase B — CCTV + street-level imagery (not yet wired).
WINDY_WEBCAMS_KEY=
MAPILLARY_CLIENT_SECRET=
MAPILLARY_ACCESS_TOKEN=

# Local LLM (Ollama) for the intel report. The backend proxies to Ollama, so no
# browser CORS config is needed — just `ollama serve` + `ollama pull <model>`.
# Defaults below are used if unset.
OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=llama3.1:8b
