# ── SENTINEL backend secrets ─────────────────────────────────────────
# Copy this file to `.env` IN THIS SAME FOLDER (the repo root — next to
# package.json). The backend reads it from here no matter where it's launched.
# `.env` is gitignored so your keys stay private.

# Port the backend listens on (REST + websocket relay).
BACKEND_PORT=8787

# Optional shared auth token. Leave blank on localhost. Set it before exposing
# the backend beyond your machine: REST then requires "Authorization: Bearer
# <token>" (or ?token=), the websocket requires /ws?token=<token>.
BACKEND_TOKEN=

# aisstream.io — free key from https://aisstream.io  (sign in with GitHub).
# Leave blank to run without live AIS; the frontend then uses its simulation.
AISSTREAM_KEY=

# OpenSky OAuth2 client credentials (optional — lifts aircraft rate limits).
# Create an API client at https://opensky-network.org  Account page.
OPENSKY_ID=
OPENSKY_SECRET=

# NASA FIRMS map key (thermal/fire layer). Free at firms.modaps.eosdis.nasa.gov.
# Leave blank to run without thermal data; the layer then reports OFF.
FIRMS_MAP_KEY=

# Local LLM (Ollama) for the intel report. The backend proxies to Ollama, so no
# browser CORS config is needed — just `ollama serve` + `ollama pull <model>`.
# Defaults below are used if unset.
OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=llama3.1:8b
